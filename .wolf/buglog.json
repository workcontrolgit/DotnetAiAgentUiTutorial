      "id": "bug-003",
      "timestamp": "2026-04-26T19:35:05.511Z",
      "error_message": "System.TypeLoadException: Could not load type 'Microsoft.Extensions.AI.FunctionApprovalRequestContent' from assembly 'Microsoft.Extensions.AI.Abstractions, Version=10.4.0.0'",
      "file": "DotnetAiAgentMcp/src/HrMcp.Agent/HrMcp.Agent.csproj",
