      "id": "bug-001",
      "timestamp": "2026-04-26T00:00:00Z",
      "error_message": "CS0121: The call is ambiguous between 'ChatClientBuilderChatClientExtensions.AsBuilder(IChatClient)' and 'EmbeddingGeneratorBuilderEmbeddingGeneratorExtensions.AsBuilder<TInput,TEmbedding>(IEmbeddingGenerator<TInput,TEmbedding>)'",
      "file": "DotnetAiAgentMcp/src/HrMcp.Agent/Program.cs",
      "root_cause": "OllamaApiClient implements both IChatClient and IEmbeddingGenerator<TInput,TEmbedding>. Calling .AsBuilder() directly is ambiguous.",
      "fix": "Cast to IChatClient first: ((IChatClient)new OllamaApiClient(...)).AsBuilder().UseFunctionInvocation().Build()",
      "tags": [
        "OllamaSharp",
        "IChatClient",
        "ambiguous-overload",
        "AsBuilder"
      ],
      "related_bugs": [],
      "occurrences": 1,
      "last_seen": "2026-04-26T00:00:00Z"
    },
