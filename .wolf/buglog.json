      "error_message": "Microsoft.Extensions.AI.Ollama deprecated — OllamaChatClient no longer recommended",
      "file": "DotnetAiAgentMcp/src/HrMcp.Agent/HrMcp.Agent.csproj, DotnetAiAgentMcp/src/HrMcp.McpServer/HrMcp.McpServer.csproj",
