<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="css/app.css" />
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
    <HeadOutlet @rendermode="RenderMode.InteractiveServer" />
</head>
<body>
    <Routes @rendermode="RenderMode.InteractiveServer" />
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="_content/Blazored.TextEditor/quill-blot-formatter.min.js"></script>
    <script src="_content/Blazored.TextEditor/Blazored-BlazorQuill.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Sets Quill's content by writing directly to root.innerHTML.
        // Quill's MutationObserver is temporarily disconnected so its normalization pass
        // cannot strip list items after the assignment. The observer is reconnected with
        // the same options Quill v1.3.6 uses so future user edits are tracked normally.
        // GetHTML() reads root.innerHTML so Word export continues to work correctly.
        function findQuillAndSetHTML(wrapperId, html) {
            var wrapper = document.getElementById(wrapperId);
            if (!wrapper) return false;
            var nodes = wrapper.querySelectorAll('*');
            for (var i = 0; i < nodes.length; i++) {
                var q = nodes[i].__quill;
                if (q && q.root) {
                    var obs = q.editor && q.editor.observer;
                    if (obs) obs.disconnect();
                    q.root.innerHTML = html;
                    if (obs) obs.observe(q.root, {
                        attributes: true,
                        characterData: true,
                        characterDataOldValue: true,
                        childList: true,
                        subtree: true
                    });
                    return true;
                }
            }
            return false;
        }

        // Sets Quill content (for use when editor is already initialized).
        window.setQuillContent = function (wrapperId, html) {
            return findQuillAndSetHTML(wrapperId, html);
        };

        // Polls until Quill's root is set (fully initialized), then loads HTML.
        // Needed because Blazor's parent OnAfterRenderAsync fires before child's createQuill completes.
        window.loadQuillWhenReady = function (wrapperId, html) {
            var attempts = 0;
            var check = setInterval(function () {
                attempts++;
                if (findQuillAndSetHTML(wrapperId, html)) { clearInterval(check); }
                else if (attempts >= 40) { clearInterval(check); }
            }, 50);
        };

        window.downloadFile = function (fileName, base64Content) {
            const byteChars = atob(base64Content);
            const byteNums = new Array(byteChars.length);
            for (let i = 0; i < byteChars.length; i++) byteNums[i] = byteChars.charCodeAt(i);
            const blob = new Blob([new Uint8Array(byteNums)], { type: 'application/octet-stream' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = fileName;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        };
    </script>
</body>
</html>
