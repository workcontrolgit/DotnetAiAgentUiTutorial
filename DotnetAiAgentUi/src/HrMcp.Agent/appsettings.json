{
  "ConnectionStrings": {
    "HrDb": "Server=(localdb)\\mssqllocaldb;Database=HrMcpDb;Trusted_Connection=True;"
  },
  "McpServer": {
    "Transport": {
      "Type": "stdio",
      "Stdio": {
        "Command": "dotnet",
        "ProjectPath": "",
        "WorkingDirectory": "C:\\apps\\DotnetAiAgentUiTutorial"
      },
      "StreamHttp": {
        "Url": "http://localhost:5100/mcp"
      }
    }
  },
  "Features": {
    "EnableOidc": true,
    "EnableDebug": false
  },
  "Oidc": {
    "Authority": "https://localhost:44310",
    "ClientId": "hr-mcp-agent",
    "ClientSecret": "hr-mcp-agent-secret",
    "Scope": "hr-mcp-api",
    "UserLogin": {
      "Authority": "https://localhost:44310",
      "ClientId": "hr-mcp-web",
      "ClientSecret": "hr-mcp-web-secret"
    }
  },
  "AI": {
    "Provider": "AzureOpenAI",
    "AzureOpenAI": {
      "Endpoint": "https://YOUR-RESOURCE-NAME.openai.azure.com/",
      "Deployment": "gpt-4.1-mini",
      "ApiKey": "YOUR_AZURE_OPENAI_KEY"
    },
    "Ollama": {
      "Endpoint": "http://localhost:11434",
      "Model": "gemma4:latest",
      "NumCtx": 32768
    }
  }
}
