    <script>
        // Finds the Quill instance inside wrapperId and sets content via dangerouslyPasteHTML.
        // This is reliable for clean HTML (no <p> inside <li>) which Markdig produces
        // when list items have no blank lines between them.
        function findQuillAndSetHTML(wrapperId, html) {
            var wrapper = document.getElementById(wrapperId);
            if (!wrapper) return false;
            var nodes = wrapper.querySelectorAll('*');
            for (var i = 0; i < nodes.length; i++) {
                var q = nodes[i].__quill;
                if (q && q.root && q.clipboard) {
                    q.clipboard.dangerouslyPasteHTML(0, html);
                    return true;
                }
            }
            return false;
        }

        // Sets Quill content (for use when editor is already initialized).
        window.setQuillContent = function (wrapperId, html) {
            return findQuillAndSetHTML(wrapperId, html);
        };

        // Reads the current HTML from the Quill root.
        window.getQuillContent = function (wrapperId) {
            var wrapper = document.getElementById(wrapperId);
            if (!wrapper) return '';
            var nodes = wrapper.querySelectorAll('*');
            for (var i = 0; i < nodes.length; i++) {
                if (nodes[i].__quill && nodes[i].__quill.root) {
                    return nodes[i].__quill.root.innerHTML;
                }
            }
            return '';
        };

        // Polls until Quill is fully initialized (clipboard ready), then loads HTML.
        // Needed because Blazor's parent OnAfterRenderAsync fires before child's createQuill completes.
        window.loadQuillWhenReady = function (wrapperId, html) {
            var attempts = 0;
            var check = setInterval(function () {
                attempts++;
                if (findQuillAndSetHTML(wrapperId, html)) { clearInterval(check); }
                else if (attempts >= 40) { clearInterval(check); }
            }, 50);
        };

