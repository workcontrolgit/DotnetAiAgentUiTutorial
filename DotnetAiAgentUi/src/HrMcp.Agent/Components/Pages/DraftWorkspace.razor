@page "/"
@page "/workspace/{SessionId:guid}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@using HrMcp.Agent.Web.Models
@using HrMcp.Agent.Web.Services
@using HrMcp.Agent.Components.Shared
@using HrMcp.Core.Interfaces
@using Markdig
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using System.Text
@using System.Text.RegularExpressions
@implements IAsyncDisposable
@inject IAgentDraftService AgentDraftService
@inject IConversationService ConversationService
@inject UserContext UserContext
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="workspace-topbar">
    <h1>Position Description Builder</h1>
    @if (_hasDraft)
    {
        <div class="layout-switcher" role="group" aria-label="Panel layout">
            <button class="layout-btn @(LayoutMode == "chat" ? "layout-btn--active" : "")"
                    title="Chat only"
                    @onclick='() => SetLayout("chat")'>
                <span class="layout-icon">&#9646;</span>
                <span class="layout-label">Chat</span>
            </button>
            <button class="layout-btn @(LayoutMode == "both" ? "layout-btn--active" : "")"
                    title="Chat and draft"
                    @onclick='() => SetLayout("both")'>
                <span class="layout-icon">&#9646;&#9646;</span>
                <span class="layout-label">Both</span>
            </button>
            <button class="layout-btn @(LayoutMode == "draft" ? "layout-btn--active" : "")"
                    title="Draft only"
                    @onclick='() => SetLayout("draft")'>
                <span class="layout-icon">&#9646;</span>
                <span class="layout-label">Draft</span>
            </button>
        </div>
    }
</div>

<div class="workspace" style="@WorkspaceGridStyle" @onmousemove="HandleResize" @onmouseup="EndResize" @onmouseleave="EndResize">
    @if (!_leftPanelHidden)
    {
        <section class="left-chat">
            <h3>Writing Assistant</h3>
            <div class="chat-thread" id="chat-thread">
                @if (_turns.Count == 0)
                {
                    <div class="chat-item">Chat responses appear here after you send a prompt.</div>
                }
                else
                {
                    @foreach (var turn in _turns)
                    {
                        var isUser = string.Equals(turn.Role, "You", StringComparison.OrdinalIgnoreCase);
                        <div class="chat-bubble-row @(isUser ? "chat-bubble-row--user" : "chat-bubble-row--assistant")">
                            <div class="chat-bubble">
                                @if (isUser)
                                {
                                    <span>@turn.Text</span>
                                }
                                else
                                {
                                    <div class="chat-bubble-content">@RenderAssistantMarkdown(turn.Text)</div>
                                }
                            </div>
                        </div>
                        @if (!isUser && turn == _turns[^1] && _seriesSuggestion.HasValue)
                        {
                            <SeriesRecommendationBanner
                                SuggestedSeries="@_seriesSuggestion.Value.Suggested"
                                SuggestedSeriesName="@_seriesSuggestion.Value.SuggestedName"
                                CurrentSeries="@_seriesSuggestion.Value.Current"
                                OnKeep="DismissSeriesSuggestion"
                                OnSwitch="AcceptSeriesSuggestion" />
                        }
                    }

                    @if (_busy)
                    {
                        <div class="chat-bubble-row chat-bubble-row--assistant">
                            <div class="chat-bubble chat-bubble--loading" role="status" aria-live="polite">
                                <span class="chat-spinner" aria-hidden="true"></span>
                                <span>Assistant is drafting your response...</span>
                            </div>
                        </div>
                    }
                    @if (_selfReviewLoading)
                    {
                        <div class="chat-bubble-row chat-bubble-row--assistant">
                            <div class="chat-bubble chat-bubble--loading" role="status" aria-live="polite">
                                <span class="chat-spinner" aria-hidden="true"></span>
                                <span>Reviewing your draft…</span>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="chat-composer">
                <textarea class="chat-input" @bind="Prompt" @bind:event="oninput" @onkeydown="HandlePromptKeyDown" placeholder="Message the assistant"></textarea>
                <div class="panel-actions panel-actions--chat">
                    <div class="panel-actions-row panel-actions-row--end">
                        <span
                            class="help-icon"
                            title="Enter to send, Shift+Enter for a new line. Draft updates automatically for draft/refine prompts."
                            aria-label="Help: Enter to send, Shift+Enter for a new line. Draft updates automatically for draft/refine prompts.">?</span>
                        <button class="primary-btn primary-btn--compact" @onclick="SendPromptAsync" disabled="@(_busy || string.IsNullOrEmpty(_userId))">Send</button>
                    </div>
                </div>
            </div>
        </section>

        @if (_draftVisible)
        {
            <div class="splitter" role="separator" aria-label="Resize chat and draft panels" @onmousedown="StartResize"></div>
        }
    }

    @if (_draftVisible)
    {
        <section class="right-editor">
            <div class="right-header">
                <h3>Your Position Description Draft</h3>
                @if (_hasDraft && !_selfReviewLoading && !_busy)
                {
                    <button class="ghost-btn" @onclick="ReReviewDraftAsync">Re-review draft</button>
                }
                <div class="export-menu-wrap">
                    <button class="ghost-btn" @onclick="ToggleExportMenu" disabled="@_busy">Export ▾</button>
                    @if (_exportMenuOpen)
                    {
                        <div class="export-menu">
                            <button class="export-menu-item" @onclick="ExportWordAsync">Word (.docx)</button>
                            <button class="export-menu-item" @onclick="ExportMarkdownAsync">Markdown (.md)</button>
                            <button class="export-menu-item" @onclick="ExportJsonAsync">JSON (.json)</button>
                        </div>
                    }
                </div>
            </div>
            <PdSectionChecklist State="_checklistState"
                                OnSectionClicked="HandleChecklistSectionClicked"
                                OnAcknowledge="HandleChecklistAcknowledge" />
            @if (_exportBusy)
            {
                <div class="export-status">
                    <span class="chat-spinner" aria-hidden="true"></span>
                    <span>Generating export...</span>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_status))
            {
                <div class="chat-item panel-status">@_status</div>
            }

            <div id="quill-editor-wrapper">
                <BlazoredTextEditor @ref="_richEditor"
                                    Placeholder="Your draft will appear here. You can edit it directly.">
                    <ToolbarContent>
                        <select class="ql-header">
                            <option selected=""></option>
                            <option value="1"></option>
                            <option value="2"></option>
                            <option value="3"></option>
                        </select>
                        <button class="ql-bold"></button>
                        <button class="ql-italic"></button>
                        <button class="ql-underline"></button>
                        <button class="ql-strike"></button>
                        <span class="ql-formats">
                            <button class="ql-list" value="ordered"></button>
                            <button class="ql-list" value="bullet"></button>
                            <button class="ql-indent" value="-1"></button>
                            <button class="ql-indent" value="+1"></button>
                        </span>
                        <button class="ql-background"></button>
                        <button class="ql-clean"></button>
                    </ToolbarContent>
                </BlazoredTextEditor>
            </div>

        </section>
    }
</div>

@code {
    private string Prompt { get; set; } = string.Empty;
    private readonly List<ChatTurn> _turns = [];
    private bool _busy;
    private bool _exportBusy;
    private string _status = string.Empty;
    private bool _leftPanelHidden;
    private bool _draftVisible;
    private bool _exportMenuOpen;
    private string? _currentDraftMarkdown;
    private BlazoredTextEditor _richEditor = default!;
    private string? _pendingHtml;
    private bool _hasDraft;
    private PdChecklistState _checklistState = new();
    private (string Suggested, string SuggestedName, string Current)? _seriesSuggestion;
    private bool _selfReviewLoading;
    private bool _selfReviewDone;
    private bool _unloadGuardRegistered;
    private bool _pendingUnloadGuardRegistration;
    private bool _resizing;
    private int _leftPanelWidth = 420;
    private const int MinLeftPanelWidth = 320;
    private const int MaxLeftPanelWidth = 760;
    private static readonly string[] DraftIntentTerms =
    [
        "draft",
        "job description",
        "jd",
        "pd",
        "position description",
        "rewrite",
        "revise",
        "refine",
        "improve",
        "edit",
        "add",
        "include",
        "qualification",
        "qualifications",
        "requirement",
        "requirements",
        // Extended terms for freeform / paste / Q&A input modes
        "position",
        "create a",
        "we're hiring",
        "we are hiring",
        "need a",
        "i need a",
        "title",
        "series",
        "grade",
        "duties",
        "clearance",
        "remote",
        "telework",
        "education",
        "supervisory",
        "gs-",
    ];
    private static readonly string[] NonDraftIntentTerms =
    [
        "list open position",
        "list open positions",
        "open position",
        "open positions",
        "show open position",
        "show open positions"
    ];
    private static readonly ChatTurn WelcomeTurn = new(
        "Assistant",
        "Hi! I'm your Position Description Writing Assistant. Let's build your PD together \u2014 " +
        "I'll ask a few quick questions first so the draft fits your position accurately.\n\n" +
        "**What position are you hiring for?** *(e.g., IT Specialist, Program Analyst, Contracting Officer)*",
        DateTimeOffset.MinValue
    );
    private static readonly MarkdownPipeline ChatMarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();
    private string WorkspaceGridStyle => LayoutMode == "both"
        ? $"grid-template-columns: {_leftPanelWidth}px 8px minmax(0, 1fr);"
        : "grid-template-columns: minmax(0, 1fr);";

    [Parameter] public Guid? SessionId { get; set; }

    private string _userId = string.Empty;

    private string LayoutMode =>
        !_draftVisible ? "chat" :
        _leftPanelHidden ? "draft" :
        "both";

    private void SetLayout(string mode)
    {
        _resizing = false;
        switch (mode)
        {
            case "chat":
                _leftPanelHidden = false;
                _draftVisible = false;
                break;
            case "draft":
                _leftPanelHidden = true;
                if (!_draftVisible && _hasDraft && _currentDraftMarkdown is not null)
                {
                    _pendingHtml = NormalizeHtmlForQuill(Markdown.ToHtml(_currentDraftMarkdown, ChatMarkdownPipeline));
                    _draftVisible = true;
                }
                break;
            case "both":
                _leftPanelHidden = false;
                if (!_draftVisible && _hasDraft && _currentDraftMarkdown is not null)
                {
                    _pendingHtml = NormalizeHtmlForQuill(Markdown.ToHtml(_currentDraftMarkdown, ChatMarkdownPipeline));
                    _draftVisible = true;
                }
                break;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingHtml is not null)
        {
            var html = _pendingHtml;
            _pendingHtml = null;
            // Quill may not be initialized yet — JS function polls until ready, then loads via dangerouslyPasteHTML
            await JS.InvokeVoidAsync("loadQuillWhenReady", "quill-editor-wrapper", html);
        }

        if (_pendingUnloadGuardRegistration)
        {
            _pendingUnloadGuardRegistration = false;
            try { await JS.InvokeVoidAsync("registerDraftUnloadGuard"); }
            catch { /* ignore if JS not ready */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_unloadGuardRegistered)
        {
            try { await JS.InvokeVoidAsync("unregisterDraftUnloadGuard"); }
            catch { /* component may be disposed before JS is available */ }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _userId = await UserContext.GetUserIdAsync() ?? string.Empty;

            if (SessionId is null)
            {
                _turns.Clear();
                _turns.Add(WelcomeTurn);
                return;
            }

            var session = await ConversationService.GetSessionAsync(SessionId.Value, _userId);
            if (session is null)
            {
                Nav.NavigateTo("/");
                return;
            }

            _turns.Clear();
            foreach (var turn in session.Turns.OrderBy(t => t.Timestamp))
            {
                var role = string.Equals(turn.Role, "user", StringComparison.OrdinalIgnoreCase) ? "You" : "Assistant";
                _turns.Add(new ChatTurn(role, turn.Text, turn.Timestamp));
            }

            // Replace draft-containing assistant turns with chat summaries
            for (var i = 0; i < _turns.Count; i++)
            {
                if (!string.Equals(_turns[i].Role, "Assistant", StringComparison.OrdinalIgnoreCase))
                    continue;
                var md = ExtractDraftMarkdown(_turns[i].Text);
                if (md is null) continue;
                _turns[i] = _turns[i] with { Text = BuildChatSummary(null, md) };
            }

            // Restore draft state from the last assistant turn that contains a draft
            var lastStoredDraftTurn = session.Turns
                .OrderBy(t => t.Timestamp)
                .LastOrDefault(t => string.Equals(t.Role, "assistant", StringComparison.OrdinalIgnoreCase)
                                 && ExtractDraftMarkdown(t.Text) is not null);
            if (lastStoredDraftTurn is not null)
            {
                var restoredMarkdown = ExtractDraftMarkdown(lastStoredDraftTurn.Text);
                if (restoredMarkdown is not null)
                {
                    _currentDraftMarkdown = restoredMarkdown;
                    _checklistState.UpdateFromDraft(_currentDraftMarkdown);
                    _hasDraft = true;
                    _pendingHtml = NormalizeHtmlForQuill(Markdown.ToHtml(_currentDraftMarkdown, ChatMarkdownPipeline));
                    _draftVisible = true;
                    if (!_unloadGuardRegistered)
                    {
                        _unloadGuardRegistered = true;
                        // Guard registered after render in OnAfterRenderAsync to ensure JS is ready
                        _pendingUnloadGuardRegistration = true;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _status = $"Error loading session: {ex.Message}";
        }
    }

    private void StartResize()
    {
        if (_leftPanelHidden)
            return;

        _resizing = true;
    }

    private void EndResize()
    {
        _resizing = false;
    }

    private void HandleResize(MouseEventArgs args)
    {
        if (!_resizing || _leftPanelHidden)
            return;

        var nextWidth = (int)args.ClientX - 24;
        _leftPanelWidth = Math.Clamp(nextWidth, MinLeftPanelWidth, MaxLeftPanelWidth);
    }

    private async Task HandlePromptKeyDown(KeyboardEventArgs args)
    {
        if (!string.Equals(args.Key, "Enter", StringComparison.Ordinal) || args.ShiftKey)
            return;

        Prompt = Prompt.TrimEnd('\r', '\n');
        await SendPromptAsync();
    }

    private async Task SendPromptAsync()
    {
        if (_busy || string.IsNullOrWhiteSpace(Prompt))
            return;

        _busy = true;
        _status = string.Empty;
        var input = Prompt.Trim();
        Prompt = string.Empty;
        // Track whether this is the first message so we can navigate after the full
        // exchange completes. Navigating early disposes the component mid-request,
        // which prevents the AI response from ever reaching the UI.
        var isFirstMessage = SessionId is null;

        try
        {
            if (isFirstMessage)
            {
                var newSession = await ConversationService.CreateSessionAsync(_userId, input);
                SessionId = newSession.Id;
            }

            _turns.Add(new ChatTurn("You", input, DateTimeOffset.UtcNow));
            await ConversationService.AddTurnAsync(SessionId!.Value, _userId, "user", input);
            await InvokeAsync(StateHasChanged);
            await JS.InvokeVoidAsync("scrollToBottom", "chat-thread");

            var response = await AgentDraftService.SendPromptAsync(input, SessionId);

            string? routedDraftMarkdown = null;
            if (ShouldSyncDraft(input, response))
                routedDraftMarkdown = ExtractDraftMarkdown(response);

            if (routedDraftMarkdown is not null)
            {
                var summary = BuildChatSummary(_currentDraftMarkdown, routedDraftMarkdown);
                _turns.Add(new ChatTurn("Assistant", summary, DateTimeOffset.UtcNow));
                await ConversationService.AddTurnAsync(SessionId.Value, _userId, "assistant", response);
                await InvokeAsync(StateHasChanged);
                await JS.InvokeVoidAsync("scrollToBottom", "chat-thread");

                bool isFirstDraft = _selfReviewDone is false;
                _currentDraftMarkdown = routedDraftMarkdown;
                var html = NormalizeHtmlForQuill(Markdown.ToHtml(routedDraftMarkdown, ChatMarkdownPipeline));
                if (!_draftVisible)
                {
                    _pendingHtml = html;
                    _draftVisible = true;
                    _hasDraft = true;
                    if (!_unloadGuardRegistered)
                    {
                        _unloadGuardRegistered = true;
                        await JS.InvokeVoidAsync("registerDraftUnloadGuard");
                    }
                }
                else
                {
                    await JS.InvokeVoidAsync("setQuillContent", "quill-editor-wrapper", html);
                }

                if (isFirstDraft)
                {
                    _selfReviewDone = true;
                    _selfReviewLoading = true;
                    await InvokeAsync(StateHasChanged);

                    _ = Task.Run(async () =>
                    {
                        var review = await AgentDraftService.GetDraftSelfReviewAsync(routedDraftMarkdown);
                        if (!string.IsNullOrWhiteSpace(review))
                            _turns.Add(new ChatTurn("Assistant", review, DateTimeOffset.UtcNow));
                        _selfReviewLoading = false;
                        await InvokeAsync(StateHasChanged);
                        await InvokeAsync(() => JS.InvokeVoidAsync("scrollToBottom", "chat-thread"));
                    });
                }
            }
            else
            {
                _turns.Add(new ChatTurn("Assistant", response, DateTimeOffset.UtcNow));
                await ConversationService.AddTurnAsync(SessionId.Value, _userId, "assistant", response);
                await InvokeAsync(StateHasChanged);
                await JS.InvokeVoidAsync("scrollToBottom", "chat-thread");
            }

            // Update checklist from the new draft markdown
            if (_currentDraftMarkdown is not null)
                _checklistState.UpdateFromDraft(_currentDraftMarkdown);

            // Detect series suggestion from AI response
            _seriesSuggestion = TryExtractSeriesSuggestion(response);
        }
        catch (Exception ex)
        {
            _turns.Add(new ChatTurn("Assistant", $"⚠ Error: {ex.Message}", DateTimeOffset.UtcNow));
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _busy = false;
        }

        // Navigate only after the full exchange is saved so the URL update doesn't
        // recreate the component and discard the in-progress AI response.
        if (isFirstMessage && SessionId.HasValue)
            Nav.NavigateTo($"/workspace/{SessionId}", forceLoad: false);
    }

    private async Task ReReviewDraftAsync()
    {
        if (_currentDraftMarkdown is null || _selfReviewLoading || _busy)
            return;

        _selfReviewLoading = true;
        await InvokeAsync(StateHasChanged);

        _ = Task.Run(async () =>
        {
            var review = await AgentDraftService.GetDraftSelfReviewAsync(_currentDraftMarkdown);
            if (!string.IsNullOrWhiteSpace(review))
                _turns.Add(new ChatTurn("Assistant", review, DateTimeOffset.UtcNow));
            _selfReviewLoading = false;
            await InvokeAsync(StateHasChanged);
            await InvokeAsync(() => JS.InvokeVoidAsync("scrollToBottom", "chat-thread"));
        });
    }

    private void ToggleExportMenu() => _exportMenuOpen = !_exportMenuOpen;

    private async Task ExportWordAsync()
    {
        _exportMenuOpen = false;
        var currentHtml = await JS.InvokeAsync<string>("getQuillContent", "quill-editor-wrapper");
        if (_busy || string.IsNullOrWhiteSpace(currentHtml) || currentHtml == "<p><br></p>")
        {
            _status = "Draft is empty. Add content before exporting.";
            return;
        }

        if (_checklistState.HasBlockingItems)
        {
            var missing = _checklistState.Sections
                .Where(s => s.IsRequired && !s.IsLocked && s.Status == PdSectionStatus.Missing)
                .Select(s => s.Name);
            _status = $"Complete all required sections before exporting: {string.Join(", ", missing)}.";
            return;
        }

        _busy = true;
        _exportBusy = true;
        _status = string.Empty;

        try
        {
            var (message, fileName, fileBytes) = await AgentDraftService.ExportDraftToWordAsync(currentHtml);

            if (fileName is not null && fileBytes is not null)
            {
                _turns.Add(new ChatTurn("Assistant", $"\u2705 Word document ready: **{fileName}**", DateTimeOffset.UtcNow));
                await InvokeAsync(StateHasChanged);
                await JS.InvokeVoidAsync("scrollToBottom", "chat-thread");
                await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(fileBytes));
            }
            else
            {
                _turns.Add(new ChatTurn("Assistant", message, DateTimeOffset.UtcNow));
                await InvokeAsync(StateHasChanged);
                await JS.InvokeVoidAsync("scrollToBottom", "chat-thread");
            }
        }
        catch (Exception ex)
        {
            _turns.Add(new ChatTurn("Assistant", $"\u26a0 Export failed: {ex.Message}", DateTimeOffset.UtcNow));
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _busy = false;
            _exportBusy = false;
        }
    }

    private async Task ExportMarkdownAsync()
    {
        _exportMenuOpen = false;
        if (_checklistState.HasBlockingItems)
        {
            var missing = _checklistState.Sections
                .Where(s => s.IsRequired && !s.IsLocked && s.Status == PdSectionStatus.Missing)
                .Select(s => s.Name);
            _status = $"Complete all required sections before exporting: {string.Join(", ", missing)}.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_currentDraftMarkdown))
        {
            _status = "Draft is empty. Add content before exporting.";
            return;
        }

        var bytes = System.Text.Encoding.UTF8.GetBytes(_currentDraftMarkdown);
        await JS.InvokeVoidAsync("downloadFile", "position-description.md", Convert.ToBase64String(bytes));
        _status = "\u2705 Markdown file ready.";
    }

    private async Task ExportJsonAsync()
    {
        _exportMenuOpen = false;
        if (_turns.Count == 0)
        {
            _status = "No conversation to export.";
            return;
        }

        var export = new
        {
            exportedAt = DateTimeOffset.UtcNow,
            draft = _currentDraftMarkdown,
            acknowledgments = _checklistState.Acknowledgments
                .Select(a => new { a.SectionName, a.AcknowledgedAt }),
            turns = _turns.Select(t => new { t.Role, t.Text, t.Timestamp })
        };

        var json = System.Text.Json.JsonSerializer.Serialize(export, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        await JS.InvokeVoidAsync("downloadFile", "position-description.json", Convert.ToBase64String(bytes));
        _status = "\u2705 JSON file ready.";
    }

    // Extracts the markdown draft body from an AI response that may include conversational
    // preamble (before the first ## heading) and a closing question/offer at the end.
    // Returns null when the response contains no markdown headings — caller skips draft update.
    internal static string? ExtractDraftMarkdown(string response)
    {
        var lines = response.Split(["\r\n", "\n"], StringSplitOptions.None);

        // Find the first line that starts a markdown heading
        var start = -1;
        for (var i = 0; i < lines.Length; i++)
        {
            if (lines[i].StartsWith('#'))
            {
                start = i;
                break;
            }
        }

        // No heading found — this is a conversational reply, do not update the draft
        if (start < 0)
            return null;

        // Strip trailing conversational closing lines (questions/offers after the last content block)
        var end = lines.Length - 1;
        while (end > start && IsClosingLine(lines[end]))
            end--;

        return string.Join("\n", lines[start..(end + 1)]).Trim();
    }

    internal static bool IsClosingLine(string line)
    {
        var t = line.Trim();
        if (string.IsNullOrWhiteSpace(t)) return true;
        // Any sentence ending in a question mark is conversational
        if (t.EndsWith("?")) return true;
        // Bullet-list question items (e.g. "- What is the clearance level?")
        if ((t.StartsWith("- ") || t.StartsWith("* ")) && t.Contains("?")) return true;
        // Conversational closers / follow-up starters
        return t.StartsWith("Do you", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Would you", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Let me know", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Feel free", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Please let me know", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("If you", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("I still need", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("I need ", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Could you", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Can you", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Please provide", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Please confirm", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("To complete", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Once you", StringComparison.OrdinalIgnoreCase)
            || t.StartsWith("Once I", StringComparison.OrdinalIgnoreCase);
    }

    internal static List<string> GetDraftSectionNames(string draftMarkdown) =>
        draftMarkdown
            .Split(["\r\n", "\n"], StringSplitOptions.None)
            .Where(line => line.StartsWith("## ", StringComparison.Ordinal))
            .Select(line => line[3..].Trim())
            .ToList();

    internal static string? ExtractPositionTitle(string draftMarkdown)
    {
        var line = draftMarkdown
            .Split(["\r\n", "\n"], StringSplitOptions.None)
            .FirstOrDefault(l => l.StartsWith("# ", StringComparison.Ordinal)
                              && !l.StartsWith("## ", StringComparison.Ordinal));
        return line?[2..].Trim();
    }

    internal static string BuildChatSummary(string? previousDraftMarkdown, string newDraftMarkdown)
    {
        var newSections = GetDraftSectionNames(newDraftMarkdown);
        var title = ExtractPositionTitle(newDraftMarkdown);
        var titleLine = title is not null ? $" \u2014 {title}" : string.Empty;

        if (previousDraftMarkdown is null)
        {
            var sectionList = newSections.Count > 0
                ? $"\nSections: {string.Join(", ", newSections)}"
                : string.Empty;
            return $"\u2705 **Draft created**{titleLine}{sectionList}";
        }

        var oldSections = GetDraftSectionNames(previousDraftMarkdown);
        var added = newSections.Except(oldSections).ToList();
        var revised = newSections.Intersect(oldSections).ToList();

        var sb = new StringBuilder();
        sb.Append($"\u2705 **Draft updated**{titleLine}");
        if (added.Count > 0)
            sb.Append($"\nAdded: {string.Join(", ", added)}");
        if (revised.Count > 0)
            sb.Append($"\nRevised: {string.Join(", ", revised)}");

        return sb.ToString();
    }

    // Markdig UseAdvancedExtensions produces loose lists: <li><p>text</p></li>.
    // Quill's MutationObserver normalizes <p> inside <li> and truncates the content.
    // Strip the <p> wrapper so Quill receives simple <li>text</li> elements.
    private static string NormalizeHtmlForQuill(string html) =>
        Regex.Replace(html, @"<li>\s*<p>(.*?)</p>\s*</li>", "<li>$1</li>", RegexOptions.Singleline);

    private static bool ShouldSyncDraft(string prompt, string response)
    {
        if (string.IsNullOrWhiteSpace(response) || string.IsNullOrWhiteSpace(prompt))
            return false;

        // Sync when the user's prompt has draft intent OR when the response itself
        // contains a PD draft (covers follow-up answers that cause section updates).
        return IsDraftIntentPrompt(prompt) || ResponseContainsDraft(response);
    }

    // Detects a PD draft in the response by checking for known section headings.
    private static bool ResponseContainsDraft(string response) =>
        response.Contains("## Position", StringComparison.OrdinalIgnoreCase) ||
        response.Contains("## Major Duties", StringComparison.OrdinalIgnoreCase) ||
        response.Contains("## Pay Plan", StringComparison.OrdinalIgnoreCase) ||
        response.Contains("## Qualifications", StringComparison.OrdinalIgnoreCase) ||
        response.Contains("## Security Clearance", StringComparison.OrdinalIgnoreCase) ||
        response.Contains("## Remote Work", StringComparison.OrdinalIgnoreCase);

    internal static bool IsDraftIntentPrompt(string prompt)
    {
        var normalized = prompt.ToLowerInvariant();

        if (NonDraftIntentTerms.Any(term => normalized.Contains(term, StringComparison.Ordinal)))
            return false;

        return DraftIntentTerms.Any(term => normalized.Contains(term, StringComparison.Ordinal));
    }

    private static MarkupString RenderAssistantMarkdown(string? text)
    {
        var source = text ?? string.Empty;

        if (TryBuildPipeTableHtml(source, out var tableHtml))
            return new MarkupString(tableHtml);

        try
        {
            var normalized = NormalizeMarkdownTables(source);
            var html = Markdown.ToHtml(normalized, ChatMarkdownPipeline);
            return new MarkupString(html);
        }
        catch
        {
            // Never break the chat render pipeline on malformed markdown.
            var fallback = $"<pre>{System.Net.WebUtility.HtmlEncode(source)}</pre>";
            return new MarkupString(fallback);
        }
    }

    private static string NormalizeMarkdownTables(string input)
    {
        if (string.IsNullOrWhiteSpace(input) || !input.Contains(":---", StringComparison.Ordinal))
            return input;

        var normalized = input;

        // Add spacing before a markdown table header if the model returns table text inline.
        normalized = Regex.Replace(normalized, "(?<=[.!?])\\s+\\|", "\\n\\n|");

        // Split flattened markdown table rows like "| Uruguay | | 2 | ..." into separate lines.
        normalized = Regex.Replace(normalized, "\\|\\s+\\|(?=\\s*\\d+\\s*\\|)", "|\\n|");

        return normalized;
    }

    private static bool TryBuildPipeTableHtml(string input, out string html)
    {
        html = string.Empty;
        if (string.IsNullOrWhiteSpace(input) || !input.Contains('|', StringComparison.Ordinal))
            return false;

        var lines = input
            .Split(["\r\n", "\n"], StringSplitOptions.None)
            .Select(line => line.TrimEnd())
            .ToList();

        var headerIndex = -1;
        for (var i = 0; i < lines.Count - 1; i++)
        {
            var headerCells = ParsePipeRow(lines[i]);
            var separatorCells = ParsePipeRow(lines[i + 1]);

            if (headerCells.Length == 0 || separatorCells.Length == 0)
                continue;

            if (separatorCells.Length == headerCells.Length && IsSeparatorRow(separatorCells))
            {
                headerIndex = i;
                break;
            }
        }

        if (headerIndex < 0)
            return false;

        var header = ParsePipeRow(lines[headerIndex]);
        if (header.Length == 0)
            return false;

        var dataRows = new List<string[]>();
        var dataStart = headerIndex + 2;
        for (var i = dataStart; i < lines.Count; i++)
        {
            var row = ParsePipeRow(lines[i]);
            if (row.Length == 0)
                break;

            dataRows.Add(row);
        }

        if (dataRows.Count == 0)
            return false;

        var sb = new StringBuilder();

        var preface = string.Join("\n", lines.Take(headerIndex)).Trim();
        if (!string.IsNullOrWhiteSpace(preface))
            sb.Append(Markdown.ToHtml(preface, ChatMarkdownPipeline));

        sb.Append("<table><thead><tr>");
        foreach (var cell in header)
            sb.Append($"<th>{System.Net.WebUtility.HtmlEncode(cell)}</th>");
        sb.Append("</tr></thead><tbody>");

        foreach (var row in dataRows)
        {
            sb.Append("<tr>");
            if (row.Length == header.Length)
            {
                foreach (var cell in row)
                    sb.Append($"<td>{System.Net.WebUtility.HtmlEncode(cell)}</td>");
            }
            else
            {
                sb.Append($"<td colspan=\"{header.Length}\">{System.Net.WebUtility.HtmlEncode(string.Join(" | ", row))}</td>");
            }

            sb.Append("</tr>");
        }

        sb.Append("</tbody></table>");

        var tailStart = dataStart + dataRows.Count;
        if (tailStart < lines.Count)
        {
            var tail = string.Join("\n", lines.Skip(tailStart)).Trim();
            if (!string.IsNullOrWhiteSpace(tail))
                sb.Append(Markdown.ToHtml(tail, ChatMarkdownPipeline));
        }

        html = sb.ToString();
        return true;
    }

    private static string[] ParsePipeRow(string row)
    {
        var trimmed = row.Trim();
        if (!trimmed.StartsWith('|') || !trimmed.EndsWith('|'))
            return [];

        return trimmed
            .Trim('|')
            .Split('|')
            .Select(cell => cell.Trim())
            .ToArray();
    }

    private static bool IsSeparatorRow(string[] cells)
    {
        return cells.All(cell => Regex.IsMatch(cell, "^:?-{3,}:?$"));
    }

    private async Task HandleChecklistSectionClicked(string sectionName)
    {
        await JS.InvokeVoidAsync("scrollQuillToHeading", "quill-editor-wrapper", sectionName);
    }

    private void HandleChecklistAcknowledge(string sectionName)
    {
        _checklistState.Acknowledge(sectionName);
    }

    private void DismissSeriesSuggestion()
    {
        _seriesSuggestion = null;
    }

    private async Task AcceptSeriesSuggestion()
    {
        if (!_seriesSuggestion.HasValue) return;
        var accepted = _seriesSuggestion.Value;
        _seriesSuggestion = null;
        // Inject a follow-up prompt so the AI updates the draft series
        Prompt = $"Please update the Pay Plan / Series / Grade section to use {accepted.Suggested} ({accepted.SuggestedName}).";
        await SendPromptAsync();
    }

    // Detects series suggestion phrases produced by the updated system prompt.
    // Expected AI format: "Series Suggestion: ... GS-XXXX (Name) ... GS-YYYY"
    // Returns (suggestedSeries, suggestedName, currentSeries) or null if not detected.
    internal static (string Suggested, string SuggestedName, string Current)? TryExtractSeriesSuggestion(string aiResponse)
    {
        if (string.IsNullOrWhiteSpace(aiResponse)) return null;

        var match = System.Text.RegularExpressions.Regex.Match(
            aiResponse,
            @"Series Suggestion.*?GS-(\d{4})\s*\(([^)]+)\).*?GS-(\d{4})",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase |
            System.Text.RegularExpressions.RegexOptions.Singleline);

        if (!match.Success) return null;

        return ($"GS-{match.Groups[1].Value}", match.Groups[2].Value.Trim(), $"GS-{match.Groups[3].Value}");
    }
}
