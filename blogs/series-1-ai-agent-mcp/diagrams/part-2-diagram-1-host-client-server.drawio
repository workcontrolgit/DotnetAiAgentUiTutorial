<mxfile host="Claude">
  <diagram name="MCP Host-Client-Server">
    <mxGraphModel dx="1200" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="520" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="MCP Architecture: Host · Client · Server" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="50" y="18" width="1000" height="36" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════
             HOST outer box
        ═══════════════════════════════════════ -->
        <mxCell id="host_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="68" width="560" height="380" as="geometry" />
        </mxCell>
        <mxCell id="host_lbl" value="Host (AI Application)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontStyle=1;fontColor=#23527c;" vertex="1" parent="1">
          <mxGeometry x="60" y="74" width="560" height="26" as="geometry" />
        </mxCell>

        <!-- LLM box inside Host -->
        <mxCell id="llm" value="&lt;b&gt;LLM&lt;/b&gt;&#xa;(Language Model)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#1a1a2e;fontSize=13;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- User box inside Host -->
        <mxCell id="user" value="&lt;b&gt;User&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="270" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- User ↔ LLM (vertical, bidirectional) -->
        <mxCell id="arr_user_llm" value="messages" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeWidth=2;strokeColor=#6c8ebf;fontSize=11;fontStyle=2;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;endArrow=block;startArrow=block;startFill=1;endFill=1;" edge="1" source="user" target="llm" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CLIENT box inside Host -->
        <mxCell id="client" value="&lt;b&gt;MCP Client&lt;/b&gt;&#xa;&#xa;· session lifecycle&#xa;· capability negotiation&#xa;· message routing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="360" y="168" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- LLM → Client (tool call dispatch) -->
        <mxCell id="arr_llm_client" value="tool call" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeWidth=2;strokeColor=#d6b656;fontSize=11;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;endArrow=block;endFill=1;" edge="1" source="llm" target="client" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client → LLM (result return) -->
        <mxCell id="arr_client_llm" value="result" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeWidth=2;strokeColor=#d6b656;fontSize=11;fontStyle=2;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;endArrow=block;endFill=1;" edge="1" source="client" target="llm" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="252"/>
              <mxPoint x="330" y="155"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════
             SERVER box (outside Host)
        ═══════════════════════════════════════ -->
        <mxCell id="server" value="&lt;b&gt;MCP Server&lt;/b&gt;&#xa;&#xa;· tools&#xa;· resources&#xa;· prompts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="780" y="168" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- JSON-RPC label on transport arrow -->
        <mxCell id="arr_client_server_fwd" value="JSON-RPC 2.0 request" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeWidth=2;strokeColor=#b85450;fontSize=11;fontStyle=2;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.35;entryDx=0;entryDy=0;endArrow=block;endFill=1;" edge="1" source="client" target="server" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr_server_client_back" value="JSON-RPC 2.0 response" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeWidth=2;strokeColor=#b85450;fontSize=11;fontStyle=2;exitX=0;exitY=0.65;exitDx=0;exitDy=0;entryX=1;entryY=0.65;entryDx=0;entryDy=0;endArrow=block;endFill=1;" edge="1" source="server" target="client" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Transport band label -->
        <mxCell id="transport_lbl" value="Transport: stdio  |  HTTP/SSE" style="text;html=1;strokeColor=#b85450;fillColor=#fff0f0;align=center;fontSize=11;fontStyle=2;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="310" width="220" height="36" as="geometry" />
        </mxCell>

        <!-- KEY INSIGHT callout at bottom -->
        <mxCell id="insight" value="&lt;i&gt;The LLM never calls the server directly.&#xa;The Host mediates every interaction.&lt;/i&gt;" style="text;html=1;strokeColor=#b85450;fillColor=#fff0f0;align=center;fontSize=12;fontStyle=0;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="460" width="500" height="44" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
