             STEP BOXES
        ═══════════════════════ -->

        <!-- Step 1 — Lane A, col 1 -->
        <mxCell id="s1" value="&lt;b&gt;1. Install SDK&lt;/b&gt;&#xa;&#xa;dotnet add package&#xa;ModelContextProtocol&#xa;.AspNetCore 1.*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#23527c;fontColor=#ffffff;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="175" y="62" width="140" height="92" as="geometry" />
        </mxCell>

        <!-- Step 2 — Lane A, col 2 -->
        <mxCell id="s2" value="&lt;b&gt;2. Write Tool Classes&lt;/b&gt;&#xa;&#xa;[McpServerToolType]&#xa;[McpServerTool]&#xa;[Description]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#23527c;fontColor=#ffffff;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="335" y="62" width="140" height="92" as="geometry" />
        </mxCell>

        <!-- Step 3 — Lane A, col 3 -->
        <mxCell id="s3" value="&lt;b&gt;3. Configure Program.cs&lt;/b&gt;&#xa;&#xa;AddMcpServer()&#xa;WithTools&lt;&gt;()&#xa;stdio / HTTP switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#23527c;fontColor=#ffffff;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="495" y="62" width="140" height="92" as="geometry" />
        </mxCell>

        <!-- Step 4 — Lane A, col 4 -->
        <mxCell id="s4" value="&lt;b&gt;4. Build&lt;/b&gt;&#xa;&#xa;dotnet build&#xa;&#xa;0 errors, 0 warnings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#23527c;fontColor=#ffffff;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="655" y="62" width="140" height="92" as="geometry" />
        </mxCell>

        <!-- Step 5 — Lane B, col 5 -->
        <mxCell id="s5" value="&lt;b&gt;5. Run HTTP Mode&lt;/b&gt;&#xa;&#xa;dotnet run&#xa;→ localhost:5100/mcp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b85450;strokeColor=#6d1f1c;fontColor=#ffffff;fontSize=11;align=center;" vertex="1" parent="1">
